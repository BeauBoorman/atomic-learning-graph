<item ID="1784483364" Creator="Beau Boorman" proto="ALG Concept" >
<attribute name="ALGId" >matrix-vector-product</attribute>
<attribute name="ALGKind" >concept</attribute>
<attribute name="ALGPrerequisites" >dot-product</attribute>
<attribute name="ALGQuotedText" >The matrix--vector product $\mathbf{A}\mathbf{x}$ is simply a column vector of length $m$, whose $i^\textrm{th}$ element is the dot product $\mathbf{a}^\top_i \mathbf{x}$: $$
\mathbf{A}\mathbf{x}
= \begin{bmatrix}
\mathbf{a}^\top_{1} \\
\mathbf{a}^\top_{2} \\
\vdots \\
\mathbf{a}^\top_m \\
\end{bmatrix}\mathbf{x}
= \begin{bmatrix}
 \mathbf{a}^\top_{1} \mathbf{x}  \\
 \mathbf{a}^\top_{2} \mathbf{x} \\
\vdots\\
 \mathbf{a}^\top_{m} \mathbf{x}\\
\end{bmatrix}.
$$</attribute>
<attribute name="ALGSourceId" >d2l-linear-algebra</attribute>
<attribute name="ALGTags" >linear algebra;matrices;matrix-vector product;vectors</attribute>
<attribute name="ALGTitle" >Matrix–Vector Product</attribute>
<attribute name="Created" >2026-07-19T12:49:19-05:00</attribute>
<attribute name="DominantLanguage" >en</attribute>
<attribute name="Height" >2.5</attribute>
<attribute name="Modified" >2026-07-19T12:49:19-05:00</attribute>
<attribute name="NLNames" >Aston Zhang</attribute>
<attribute name="NLOrganizations" >Lipton</attribute>
<attribute name="NLPlaces" >Alexander</attribute>
<attribute name="Name" >Matrix–Vector Product</attribute>
