<attribute name="ScreenHeight" >67</attribute>
<attribute name="ScreenWidth" >132</attribute>
<attribute name="Sentiment" >-0.5000000156</attribute>
<attribute name="Sentiments" >-0.4;-0.8;-0.8;-0.6;-0.8;-0.6;-0.6;-0.2;-0.6;-0.4;-0.6;-0.6;-0.6;-0.6;-0.2;-0.6;-0.6;-0.6;-0.8;-0.6;-0.2;0.8</attribute>
