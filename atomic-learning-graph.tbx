<attribute name="Sentiments" >-0.4;-1;-0.8;-0.6;-0.6;-0.4;-0.6;-1;-0.6;-0.4;-0.4;-0.6;-1;-0.6;-0.6;-0.4;-0.6;-0.6;-0.8;-0.4;-0.8;0.2</attribute>
