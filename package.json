{
  "name": "atomic-learning-graph",
  "version": "0.1.0",
  "private": true,
  "description": "Open Atomic Learning Graph — turn open educational resources into a navigable prerequisite graph of one-concept lessons.",
  "license": "MIT AND CC-BY-SA-4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --config vite.single.config.ts && node --import tsx scripts/inline-single.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "estimate:cost": "node --import tsx scripts/estimate-cost.ts",
    "typecheck": "tsc --noEmit",
    "fetch:corpus": "tsx scripts/fetch-corpus.ts",
    "verify:corpus": "node --import tsx scripts/verify-corpus.ts",
    "verify:anchors": "node --import tsx scripts/verify-anchors.ts",
    "emit:llms": "node --import tsx scripts/emit-llms.ts",
    "verify:llms": "node --import tsx scripts/emit-llms.ts --verify",
    "emit:receipt": "node --import tsx scripts/emit-receipt.ts",
    "verify:receipt": "node --import tsx scripts/emit-receipt.ts --verify",
    "emit:orgroam": "node --import tsx scripts/emit-orgroam.ts",
    "verify:orgroam": "node --import tsx scripts/emit-orgroam.ts --verify",
    "emit:anki": "node --import tsx scripts/emit-anki.ts",
    "verify:anki": "node --import tsx scripts/emit-anki.ts --verify",
    "emit:obsidian": "node --import tsx scripts/emit-obsidian.ts",
    "verify:obsidian": "node --import tsx scripts/emit-obsidian.ts --verify",
    "emit:exam": "node --import tsx scripts/emit-exam.ts",
    "verify:exam": "node --import tsx scripts/emit-exam.ts --verify",
    "verify:bundle": "node --import tsx scripts/verify-bundle.ts",
    "verify:single": "node --import tsx scripts/verify-single.ts",
    "demo:tamper": "node --import tsx scripts/demo-tamper.ts",
    "gate": "bash scripts/gate.sh",
    "atomize": "tsx src/atomization/atomize.ts",
    "atomize:toy": "tsx src/atomization/atomize.ts --toy",
    "render": "tsx src/atomization/render.ts"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "cytoscape": "^3.34.0",
    "cytoscape-dagre": "^4.0.0",
    "katex": "^0.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
