# dependencies
node_modules/
.pnpm-store/

# secrets — never commit an API key (OPENAI_API_KEY etc.)
.env
.env.*
!.env.example

# build output
dist/
dist-single/
build/
.next/
out/
*.tsbuildinfo

# generated artifacts (produced by `pnpm atomize`)
#
# NOTE: `data/graph.json` is deliberately NOT ignored — it is a COMMITTED build artifact.
# The deployed app is static (SSG) and must ship with a graph; running `atomize` in CI would
# put a live LLM call on the deploy path. See docs/adr/001-commit-the-generated-graph.md.
# Do not add data/graph.json here.

# internal working notes — THIS REPO GOES PUBLIC.
#
# plans/ holds the review brief, the adversarial review-panel output, the internal risk register,
# and the honest "what doesn't exist yet" list. None of that is for judges. It was previously only
# UNTRACKED, which meant a reflexive `git add -A` would have published all of it.
plans/

# test / tooling
coverage/
.vitest/
.vercel/

# os
.DS_Store

# Internal working notes — MUST NOT ship to the public repo

# local agent/tool config — never part of the public submission
.claude/

# camera artifacts — deliberately-unpinned experimental runs.
# NOT the product. Never committed: an unpinned graph has no golden spine protecting
# it and may not contain the goal at all. See ROADMAP.
.artifacts/
