# dependencies
node_modules/
.pnpm-store/

# secrets — never commit an API key (OPENAI_API_KEY etc.)
.env
.env.*
!.env.example

# build output
dist/
build/
.next/
out/
*.tsbuildinfo

# generated artifacts (produced by `pnpm atomize`)
#
# NOTE: `data/graph.json` is deliberately NOT ignored — it is a COMMITTED build artifact.
# The deployed app is static (SSG) and must ship with a graph; running `atomize` in CI would
# put a live LLM call on the deploy path. See docs/adr/001-commit-the-generated-graph.md.
# Do not add data/graph.json here.

# test / tooling
coverage/
.vitest/
.vercel/

# os
.DS_Store

# Internal working notes — MUST NOT ship to the public repo
plans/
